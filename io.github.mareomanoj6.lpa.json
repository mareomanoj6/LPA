{
  "app-id": "io.github.mareomanoj6.lpa",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "lpa",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=com.canonical.AppMenu.Registrar",
    "--own-name=org.mpris.MediaPlayer2.io.github.mareomanoj6.lpa",
    "--filesystem=~/.local/share/lpa:create"
  ],
  "modules": [
    "python3-yt-dlp.json",
    "libayatana-appindicator-gtk3.json",
    {
      "name": "lpa",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 lpa.py /app/bin/lpa",
        "cp -r data audio ui tray assets /app/bin/",
        "cp -r sounds /app/bin/sounds",
        "install -Dm644 io.github.mareomanoj6.lpa.desktop /app/share/applications/io.github.mareomanoj6.lpa.desktop",
        "install -Dm644 assets/logo.png /app/share/icons/hicolor/256x256/apps/io.github.mareomanoj6.lpa.png",
        "install -Dm644 assets/logo.png /app/share/icons/hicolor/64x64/apps/io.github.mareomanoj6.lpa.png",
        "install -Dm644 assets/logo.png /app/share/icons/hicolor/24x24/apps/io.github.mareomanoj6.lpa.png",
        "install -Dm644 io.github.mareomanoj6.lpa.metainfo.xml /app/share/metainfo/io.github.mareomanoj6.lpa.metainfo.xml"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
